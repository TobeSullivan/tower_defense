# Copy to .env (gitignored) on the server and fill in real secrets before `docker compose up`.
# Generate strong values, e.g.:  openssl rand -hex 24

# Postgres password (used by both services over the private compose network).
POSTGRES_PASSWORD=change_me_postgres

# Nakama client "server key" — the shared key the Godot client authenticates the API with.
# This is NOT a user password; it gates API access. Set the same value in the Godot client.
NAKAMA_SERVER_KEY=change_me_server_key

# Developer console (https://<box>:7351) login. Firewall 7351 to your own IP.
NAKAMA_CONSOLE_USER=admin
NAKAMA_CONSOLE_PASSWORD=change_me_console
